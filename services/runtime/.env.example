# YagaAi Runtime Configuration
# Copy to .env and adjust as needed.

# Environment mode: local-dev | prod
# YAGA_ENV=local-dev

# SQLite database file path (relative to services/runtime/)
# YAGA_SQLITE_PATH=yaga.db

# Bearer token for bootstrap auth on non-webhook endpoints
# YAGA_BOOTSTRAP_BEARER_TOKEN=<your-token>

# HMAC signing secret for publication webhook callbacks
# YAGA_WEBHOOK_SIGNING_SECRET=<your-secret>

# Default execution assignee agent ID
# YAGA_DEFAULT_ASSIGNEE_AGENT_ID=naomi
